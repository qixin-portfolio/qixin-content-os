generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum SourceType {
  github
  markdown
  document
  image
  manual
}

enum Platform {
  wechat_moments
  x
  xiaohongshu
  douyin
}

enum Recommendation {
  publish_now
  combine_later
  archive_only
}

enum AngleType {
  personal_growth
  build_in_public
  industry_observation
  practical_method
  commercial_experiment
}

enum EditorialStatus {
  draft
  needs_review
  editing
  approved
  rejected
}

enum ChangeSource {
  ai_initial
  ai_suggestion
  human_edit
  human_approval
}

enum VoiceSampleSourceType {
  manual_input
  approved_draft
  imported_post
}

model Project {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  status      String       @default("active")
  projectSources ProjectSource[]
  sourceItems SourceItem[]
  eventCards  EventCard[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ProjectSource {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType   SourceType
  sourceName   String
  sourcePath   String?
  repository   String?
  metadataJson String?
  sourceItems  SourceItem[]
  createdAt    DateTime     @default(now())
}

model SourceItem {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectSourceId String?
  projectSource   ProjectSource? @relation(fields: [projectSourceId], references: [id], onDelete: SetNull)
  sourceType      SourceType
  title           String
  content         String
  sourceUrl       String?
  sourcePath      String?
  visibility      String         @default("private")
  eventCards      EventCard[]
  createdAt       DateTime       @default(now())
}

model EventCard {
  id                 String        @id @default(cuid())
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  whatHappened       String
  whyItMatters       String
  problem            String
  result             String
  personalReflection String
  evidenceRequired   String
  status             String        @default("inbox")
  masterContent      MasterContent?
  assets             Asset[]
  sourceItems        SourceItem[]
  contentScore       ContentScore?
  contentAngles      ContentAngle[]
  createdAt          DateTime      @default(now())
}

model MasterContent {
  id             String            @id @default(cuid())
  eventCardId    String            @unique
  eventCard      EventCard         @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  title          String
  hook           String
  story          String
  insight        String
  reflection     String
  cta            String
  status         String            @default("drafting")
  factReferencesJson String?
  platformVariants PlatformVariant[]
  editorialDrafts EditorialDraft[]
  createdAt      DateTime          @default(now())
}

model ContentScore {
  id             String         @id @default(cuid())
  eventCardId    String         @unique
  eventCard      EventCard      @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  noveltyScore   Int
  personalScore  Int
  industryScore  Int
  visualScore    Int
  businessScore  Int
  totalScore     Int
  recommendation Recommendation
  reason         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ContentAngle {
  id                       String    @id @default(cuid())
  eventCardId              String
  eventCard                EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  angleType                AngleType
  title                    String
  coreIdea                 String
  targetAudience           String
  recommendedPlatformsJson String
  reason                   String
  selected                 Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model VoiceProfile {
  id                String   @id @default(cuid())
  name              String
  platform          Platform
  tone              String
  preferredWordsJson String
  avoidWordsJson    String
  writingRulesJson  String
  exampleTextsJson  String
  isDefault         Boolean  @default(false)
  voiceSamples      VoiceSample[]
  editorialDrafts   EditorialDraft[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EditorialDraft {
  id                String          @id @default(cuid())
  masterContentId   String
  masterContent     MasterContent   @relation(fields: [masterContentId], references: [id], onDelete: Cascade)
  voiceProfileId    String?
  voiceProfile      VoiceProfile?   @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  platform          Platform
  title             String
  body              String
  hook              String
  cta               String
  status            EditorialStatus @default(draft)
  currentRevisionId String?         @unique
  currentRevision   DraftRevision?  @relation("CurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  revisions         DraftRevision[] @relation("DraftRevisions")
  styleReviews      StyleReview[]
  approvedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([masterContentId, platform])
}

model DraftRevision {
  id               String          @id @default(cuid())
  editorialDraftId String
  editorialDraft   EditorialDraft  @relation("DraftRevisions", fields: [editorialDraftId], references: [id], onDelete: Cascade)
  currentForDraft  EditorialDraft? @relation("CurrentRevision")
  revisionNumber   Int
  title            String
  body             String
  hook             String
  cta              String
  changeSource     ChangeSource
  changeSummary    String
  createdAt        DateTime        @default(now())

  @@unique([editorialDraftId, revisionNumber])
}

model VoiceSample {
  id                String                @id @default(cuid())
  voiceProfileId    String
  voiceProfile      VoiceProfile          @relation(fields: [voiceProfileId], references: [id], onDelete: Cascade)
  platform          Platform
  title             String
  body              String
  sourceType        VoiceSampleSourceType
  sourceReferenceId String
  qualityRating     Int
  notes             String
  approved          Boolean               @default(false)
  active            Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model StyleReview {
  id                String         @id @default(cuid())
  editorialDraftId  String
  editorialDraft    EditorialDraft @relation(fields: [editorialDraftId], references: [id], onDelete: Cascade)
  overallScore      Int
  aiToneScore       Int
  authenticityScore Int
  clarityScore      Int
  salesToneScore    Int
  issuesJson        String
  suggestionsJson   String
  createdAt         DateTime       @default(now())
}

model PlatformVariant {
  id             String          @id @default(cuid())
  masterContentId String
  masterContent   MasterContent  @relation(fields: [masterContentId], references: [id], onDelete: Cascade)
  platform       Platform
  title          String
  body           String
  status         String          @default("drafting")
  publishRecords PublishRecord[]

  @@unique([masterContentId, platform])
}

model Asset {
  id          String    @id @default(cuid())
  eventCardId String
  eventCard   EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  type        String
  url         String
  description String?
  visibility  String    @default("private")
}

model PublishRecord {
  id                String          @id @default(cuid())
  platformVariantId String
  platformVariant   PlatformVariant @relation(fields: [platformVariantId], references: [id], onDelete: Cascade)
  platform          Platform
  publishedUrl      String?
  publishedAt       DateTime?
  metricsJson       String?
}
