generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum SourceType {
  github
  markdown
  document
  image
  manual
  obsidian_vault
}

enum EvidenceStrength {
  strong
  medium
  weak
}

enum TopicCandidateStatus {
  proposed
  shortlisted
  rejected
  converted
}

enum TopicSourceRole {
  primary_reference
  supporting_reference
  contrary_reference
}

enum Platform {
  wechat_moments
  x
  xiaohongshu
  douyin
}

enum Recommendation {
  publish_now
  combine_later
  archive_only
}

enum AngleType {
  personal_growth
  build_in_public
  industry_observation
  practical_method
  commercial_experiment
}

enum EditorialStatus {
  draft
  needs_review
  editing
  approved
  rejected
}

enum ChangeSource {
  ai_initial
  ai_suggestion
  human_edit
  human_approval
}

enum VoiceSampleSourceType {
  manual_input
  approved_draft
  imported_post
}

enum PublicationPackageStatus {
  ready
  exported
  published
  archived
}

enum ExportFormat {
  txt
  markdown
  json
}

model Project {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  status      String       @default("active")
  projectSources ProjectSource[]
  sourceItems SourceItem[]
  eventCards  EventCard[]
  topicCandidates TopicCandidate[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ProjectSource {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType   SourceType
  sourceName   String
  displayName  String?
  sourcePath   String?
  repository   String?
  metadataJson String?
  vaultKey     String?      @unique
  sourceCategory String?
  rootFingerprint String?
  lastScannedAt DateTime?
  enabled      Boolean      @default(true)
  sourceItems  SourceItem[]
  scanRuns     ScanRun[]
  createdAt    DateTime     @default(now())
}

model SourceItem {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectSourceId String?
  projectSource   ProjectSource? @relation(fields: [projectSourceId], references: [id], onDelete: SetNull)
  sourceType      SourceType
  title           String
  content         String
  sourceUrl       String?
  sourcePath      String?
  relativePath    String?
  author          String?
  publishedAt     DateTime?
  modifiedAt      DateTime?
  tagsJson        String?
  contentHash     String?
  summary         String?
  riskFlagsJson   String?
  sourceCategory  String?
  factEligibility String?
  linksJson       String?
  attachmentRefsJson String?
  sourceMissingAt DateTime?
  visibility      String         @default("private")
  eventCards      EventCard[]
  versions        SourceItemVersion[]
  topicCandidateSources TopicCandidateSource[]
  createdAt       DateTime       @default(now())

  @@unique([projectSourceId, relativePath])
}

model SourceItemVersion {
  id            String     @id @default(cuid())
  sourceItemId  String
  sourceItem    SourceItem @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  content       String
  summary       String
  contentHash   String
  sourceUrl     String?
  modifiedAt    DateTime?
  observedAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())

  @@unique([sourceItemId, contentHash])
  @@index([sourceItemId, createdAt])
}

model ScanRun {
  id              String        @id @default(cuid())
  projectSourceId String
  projectSource   ProjectSource @relation(fields: [projectSourceId], references: [id], onDelete: Cascade)
  vaultKey        String
  scanMode        String
  discoveredCount Int           @default(0)
  validCount      Int           @default(0)
  skippedCount    Int           @default(0)
  duplicateCount  Int           @default(0)
  riskCount       Int           @default(0)
  startedAt       DateTime
  completedAt     DateTime?
  manifestHash    String?
  status          String        @default("running")

  @@index([projectSourceId, startedAt])
}

model TopicCandidate {
  id                    String                 @id @default(cuid())
  projectId             String
  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                 String
  targetAudience        String
  userPainPoint         String
  coreAngle             String
  evidenceStrength      EvidenceStrength
  freshness             String
  suggestedPlatformsJson String
  riskFlagsJson         String
  sourceCategory        String                 @default("external_research")
  factEligibility       String                 @default("unverified_reference")
  researchWorthiness    Boolean?
  firstHandEvidenceNeeded String?
  fitsCurrentProject    Boolean?
  humanNotes            String?
  status                TopicCandidateStatus   @default(proposed)
  sources               TopicCandidateSource[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([projectId, title])
}

model TopicCandidateSource {
  id               String             @id @default(cuid())
  topicCandidateId String
  topicCandidate   TopicCandidate     @relation(fields: [topicCandidateId], references: [id], onDelete: Cascade)
  sourceItemId     String
  sourceItem       SourceItem         @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  relevance        String
  sourceRole       TopicSourceRole

  @@unique([topicCandidateId, sourceItemId])
  @@index([sourceItemId])
}

model EventCard {
  id                 String        @id @default(cuid())
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  whatHappened       String
  whyItMatters       String
  problem            String
  result             String
  personalReflection String
  evidenceRequired   String
  status             String        @default("inbox")
  masterContent      MasterContent?
  assets             Asset[]
  sourceItems        SourceItem[]
  contentScore       ContentScore?
  contentAngles      ContentAngle[]
  createdAt          DateTime      @default(now())
}

model MasterContent {
  id             String            @id @default(cuid())
  eventCardId    String            @unique
  eventCard      EventCard         @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  title          String
  hook           String
  story          String
  insight        String
  reflection     String
  cta            String
  status         String            @default("drafting")
  factReferencesJson String?
  platformVariants PlatformVariant[]
  editorialDrafts EditorialDraft[]
  createdAt      DateTime          @default(now())
}

model ContentScore {
  id             String         @id @default(cuid())
  eventCardId    String         @unique
  eventCard      EventCard      @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  noveltyScore   Int
  personalScore  Int
  industryScore  Int
  visualScore    Int
  businessScore  Int
  totalScore     Int
  recommendation Recommendation
  reason         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ContentAngle {
  id                       String    @id @default(cuid())
  eventCardId              String
  eventCard                EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  angleType                AngleType
  title                    String
  coreIdea                 String
  targetAudience           String
  recommendedPlatformsJson String
  reason                   String
  selected                 Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model VoiceProfile {
  id                String   @id @default(cuid())
  name              String
  platform          Platform
  tone              String
  preferredWordsJson String
  avoidWordsJson    String
  writingRulesJson  String
  exampleTextsJson  String
  isDefault         Boolean  @default(false)
  voiceSamples      VoiceSample[]
  editorialDrafts   EditorialDraft[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EditorialDraft {
  id                String          @id @default(cuid())
  masterContentId   String
  masterContent     MasterContent   @relation(fields: [masterContentId], references: [id], onDelete: Cascade)
  voiceProfileId    String?
  voiceProfile      VoiceProfile?   @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  platform          Platform
  title             String
  body              String
  hook              String
  cta               String
  status            EditorialStatus @default(draft)
  currentRevisionId String?         @unique
  currentRevision   DraftRevision?  @relation("CurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  revisions         DraftRevision[] @relation("DraftRevisions")
  styleReviews      StyleReview[]
  publicationPackages PublicationPackage[]
  approvedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([masterContentId, platform])
}

model DraftRevision {
  id                       String          @id @default(cuid())
  editorialDraftId         String
  editorialDraft           EditorialDraft  @relation("DraftRevisions", fields: [editorialDraftId], references: [id], onDelete: Cascade)
  currentForDraft          EditorialDraft? @relation("CurrentRevision")
  approvedSourceRevisionId String?         @unique
  revisionNumber           Int
  title                    String
  body                     String
  hook                     String
  cta                      String
  changeSource             ChangeSource
  changeSummary            String
  sourcePublicationPackages   PublicationPackage[] @relation("PublicationSourceRevision")
  approvalPublicationPackages PublicationPackage[] @relation("PublicationApprovalRevision")
  createdAt                DateTime        @default(now())

  @@unique([editorialDraftId, revisionNumber])
}

model VoiceSample {
  id                String                @id @default(cuid())
  voiceProfileId    String
  voiceProfile      VoiceProfile          @relation(fields: [voiceProfileId], references: [id], onDelete: Cascade)
  platform          Platform
  title             String
  body              String
  sourceType        VoiceSampleSourceType
  sourceReferenceId String
  sourceRevisionId  String?               @unique
  qualityRating     Int
  notes             String
  approved          Boolean               @default(false)
  active            Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model StyleReview {
  id                String         @id @default(cuid())
  editorialDraftId  String
  editorialDraft    EditorialDraft @relation(fields: [editorialDraftId], references: [id], onDelete: Cascade)
  overallScore      Int
  aiToneScore       Int
  authenticityScore Int
  clarityScore      Int
  salesToneScore    Int
  issuesJson        String
  suggestionsJson   String
  createdAt         DateTime       @default(now())
}

model PublicationPackage {
  id                    String                   @id @default(cuid())
  editorialDraftId      String
  editorialDraft        EditorialDraft           @relation(fields: [editorialDraftId], references: [id], onDelete: Cascade)
  sourceRevisionId      String
  sourceRevision        DraftRevision             @relation("PublicationSourceRevision", fields: [sourceRevisionId], references: [id], onDelete: Restrict)
  approvalRevisionId    String
  approvalRevision      DraftRevision             @relation("PublicationApprovalRevision", fields: [approvalRevisionId], references: [id], onDelete: Restrict)
  platform              Platform
  title                 String?
  hook                  String?
  body                  String
  cta                   String?
  status                PublicationPackageStatus @default(ready)
  evidenceSnapshotJson  String
  factBoundaryJson      String
  assetBriefJson        String
  publishChecklistJson  String
  packageHash           String
  publishedAt           DateTime?
  publishedUrl          String?
  publishNotes          String?
  exports               PublicationExport[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([sourceRevisionId, platform])
  @@index([editorialDraftId])
}

model PublicationExport {
  id                   String             @id @default(cuid())
  publicationPackageId String
  publicationPackage   PublicationPackage @relation(fields: [publicationPackageId], references: [id], onDelete: Cascade)
  format               ExportFormat
  fileName             String
  contentHash          String
  createdAt            DateTime           @default(now())

  @@index([publicationPackageId])
}

model PlatformVariant {
  id             String          @id @default(cuid())
  masterContentId String
  masterContent   MasterContent  @relation(fields: [masterContentId], references: [id], onDelete: Cascade)
  platform       Platform
  title          String
  body           String
  status         String          @default("drafting")
  publishRecords PublishRecord[]

  @@unique([masterContentId, platform])
}

model Asset {
  id          String    @id @default(cuid())
  eventCardId String
  eventCard   EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  type        String
  url         String
  description String?
  visibility  String    @default("private")
}

model PublishRecord {
  id                String          @id @default(cuid())
  platformVariantId String
  platformVariant   PlatformVariant @relation(fields: [platformVariantId], references: [id], onDelete: Cascade)
  platform          Platform
  publishedUrl      String?
  publishedAt       DateTime?
  metricsJson       String?
}
