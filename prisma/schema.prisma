generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum SourceType {
  github
  markdown
  document
  image
  manual
}

enum Platform {
  wechat_moments
  x
  xiaohongshu
  douyin
}

model Project {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  status      String       @default("active")
  projectSources ProjectSource[]
  sourceItems SourceItem[]
  eventCards  EventCard[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ProjectSource {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType   SourceType
  sourceName   String
  sourcePath   String?
  repository   String?
  metadataJson String?
  sourceItems  SourceItem[]
  createdAt    DateTime     @default(now())
}

model SourceItem {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectSourceId String?
  projectSource   ProjectSource? @relation(fields: [projectSourceId], references: [id], onDelete: SetNull)
  sourceType      SourceType
  title           String
  content         String
  sourceUrl       String?
  sourcePath      String?
  visibility      String         @default("private")
  eventCards      EventCard[]
  createdAt       DateTime       @default(now())
}

model EventCard {
  id                 String        @id @default(cuid())
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  whatHappened       String
  whyItMatters       String
  problem            String
  result             String
  personalReflection String
  evidenceRequired   String
  status             String        @default("inbox")
  masterContent      MasterContent?
  assets             Asset[]
  sourceItems        SourceItem[]
  createdAt          DateTime      @default(now())
}

model MasterContent {
  id             String            @id @default(cuid())
  eventCardId    String            @unique
  eventCard      EventCard         @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  title          String
  hook           String
  story          String
  insight        String
  reflection     String
  cta            String
  status         String            @default("drafting")
  platformVariants PlatformVariant[]
  createdAt      DateTime          @default(now())
}

model PlatformVariant {
  id             String          @id @default(cuid())
  masterContentId String
  masterContent   MasterContent  @relation(fields: [masterContentId], references: [id], onDelete: Cascade)
  platform       Platform
  title          String
  body           String
  status         String          @default("drafting")
  publishRecords PublishRecord[]

  @@unique([masterContentId, platform])
}

model Asset {
  id          String    @id @default(cuid())
  eventCardId String
  eventCard   EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  type        String
  url         String
  description String?
  visibility  String    @default("private")
}

model PublishRecord {
  id                String          @id @default(cuid())
  platformVariantId String
  platformVariant   PlatformVariant @relation(fields: [platformVariantId], references: [id], onDelete: Cascade)
  platform          Platform
  publishedUrl      String?
  publishedAt       DateTime?
  metricsJson       String?
}
